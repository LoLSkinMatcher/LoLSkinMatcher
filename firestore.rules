rules_version = '2';

// Friends-scale rules: anonymous auth required for everything, documents
// must match the expected shape, and sizes are capped. The data itself
// (skin lists keyed by PUUID) is not sensitive, but these rules stop
// random abuse and quota burning.
service cloud.firestore {
  match /databases/{database}/documents {

    match /libraries/{puuid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(
             ['player', 'puuid', 'updatedAt', 'data'])
        && request.resource.data.player is string
        && request.resource.data.puuid == puuid
        && request.resource.data.data is string
        && request.resource.data.data.size() < 500000;
    }

    match /parties/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(
             ['state', 'captain', 'updatedAt'])
        && request.resource.data.state is string
        && request.resource.data.state.size() < 200000;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
